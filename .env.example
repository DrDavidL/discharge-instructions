# Copy to .env for local development. On Railway, set these in the service Variables tab.

# --- LLM (OpenRouter) ---
OPENROUTER_API_KEY=sk-or-...
MODEL=anthropic/claude-sonnet-4.6
# Optional OpenRouter attribution headers
OPENROUTER_SITE_URL=https://your-app.up.railway.app
OPENROUTER_APP_NAME=Discharge Instructions Coach
# Abort a scoring call that stalls this many ms (so it returns a clear error instead of
# hanging until the platform edge proxy returns a bodyless 502). Default 90000 (90s).
# OPENROUTER_TIMEOUT_MS=90000

# --- Shared password login (no PHI / no student PII is stored) ---
APP_PASSWORD=change-me-to-a-shared-class-password
# Secret used to sign session tokens. Generate with: openssl rand -hex 32
AUTH_SECRET=change-me-long-random-string

# --- Database (Railway provides this automatically; leave blank locally to run without persistence) ---
# DATABASE_URL=postgresql://user:pass@host:port/dbname
# Override TLS behavior if needed: "true" forces TLS, "false" disables it. Default: off for localhost, on otherwise.
# DATABASE_SSL=true

# --- Server ---
# Railway sets PORT automatically; defaults to 8080 locally.
PORT=8080
